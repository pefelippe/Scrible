{
  "name": "scribe-server",
  "version": "1.0.0",
  "private": true,
  "description": "AI Scribe Notes API - Express + Prisma + OpenAI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
