# OpenAI API key used for Whisper transcription and SOAP summaries
OPENAI_API_KEY=sk-...

# Neon database connection string (local dev: use docker-compose postgres or local instance)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Secret used to sign JWT session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# Optional S3 audio storage. Leave S3_BUCKET unset to store audio locally.
# Credentials/region resolve via the standard AWS chain (env vars, profile).
# S3_BUCKET=my-scribe-audio
# S3_ENDPOINT=http://localhost:4566   # e.g. LocalStack or Cloudflare R2
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# API server port
PORT=4000

# Set to "on" to seed the database on startup
SEED=off
